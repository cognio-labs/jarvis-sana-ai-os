{
  "extends": ["next/core-web-vitals", "plugin:@next/next/recommended"],
  "plugins": ["@next/eslint-plugin-next"],
  "parserOptions": {
    "project": "./tsconfig.json"
  },
  "rules": {
    // Add or override rules here
    "@next/next/no-img-element": "off", // Example: Allow <img> elements if needed
    "react/jsx-key": "warn", // Warn about missing keys in JSX
    "no-console": "warn" // Warn about console logs in development, error in production
  },
  "ignorePatterns": ["node_modules/", ".next/", "dist/", "*.js", "*.jsx"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx"],
      "parserOptions": {
        "project": "./tsconfig.json"
      }
    }
  ]
}
