# Environment Variables - Example (Copy to .env and fill values)

# Node JS & Next.js
NODE_ENV=development
PORT=3000

# AI Core Settings
OPENROUTER_API_KEY=pk-your-openrouter-api-key-here
OPENROUTER_PRIMARY_MODEL=openrouter/google/gemini-2.5-flash-preview
OPENROUTER_FALLBACK_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct
OPENROUTER_BACKUP_MODEL=openrouter/deepseek/deepseek-chat-v3
OPENROUTER_REQUEST_TIMEOUT=180000
AGENT_TIMEOUT=300000
RETRY_ATTEMPTS=5
RETRY_BACKOFF_FACTOR=2

# Local AI (Ollama)
USE_LOCAL_AI=false
OLLAMA_BASE_URL=http://localhost:11434

# LangChain Settings
LANGCHAIN_DEFAULT_MODEL=openrouter/google/gemini-2.5-flash-preview
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY # Uncomment if using OpenAI directly and not OpenRouter
MEMORY_STORE_URL=

# Task Queue (Example: Redis URL)
TASK_QUEUE_URL=

# Security
API_KEY=sk-your-secure-api-key-for-internal-use

# Logging
LOG_LEVEL=DEBUG
